# ─── Stock Analyzer Pro — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your API keys

# [REQUIRED] Anthropic Claude API Key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# [OPTIONAL] Claude model to use (default: claude-opus-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# [OPTIONAL] NewsAPI key — for extended news coverage
# Get yours at: https://newsapi.org (free plan available)
# NEWS_API_KEY=your_newsapi_key_here
